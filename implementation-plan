Wildcard Matching:

bool matchWildcard(const std::vector<uint8_t>& data, size_t offset,
                   const std::vector<WildcardToken>& tokens) {
  size_t dataIdx = offset;
  size_t tokenIdx = 0;
  
  while (tokenIdx < tokens.size() && dataIdx < data.size()) {
    const auto& token = tokens[tokenIdx];
    
    switch (token.type) {
      case TokenType::EXACT:
        if (data[dataIdx] != token.value[0]) return false;
        dataIdx++; tokenIdx++;
        break;
        
      case TokenType::ANY_BYTE:
        dataIdx++; tokenIdx++;
        break;
        
      case TokenType::ANY_SEQUENCE:
        // Greedy or non-greedy matching
        // Try to match rest of pattern
        // ...
        break;
    }
  }
  
  return tokenIdx == tokens.size();
}
