      // ...
    } else if (pattern[i] == '{') {
      // Parse one-of {00,08,09}
      // ...
    } else {
      // Exact byte
      tokens.push_back({TokenType::EXACT, {pattern[i]}});
      i++;
    }
  }
  
  return tokens;
